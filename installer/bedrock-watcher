#!/usr/bin/env python3
"""bedrock-watcher — per-node log-driven config watcher.

Polls /run/bedrock-rust.sock for the current log latest_index. Keeps
an in-memory snapshot up-to-date by folding ONLY new entries since
the last poll (O(new_entries), not O(log_size)). On any change that
projects to a different daemon.toml content, regenerates daemon.toml
and restarts bedrock-rust.

This is the per-node side of "log-driven config propagation": the
master appends a log entry; replication carries it to every peer;
each peer's watcher detects the new index, folds the new entries,
and reconfigures locally. No SSH between nodes.

Idempotent. Safe to start any time. Survives bedrock-rust restarts
(reconnects on next poll).
"""
from __future__ import annotations
import hashlib
import sys
import time
from pathlib import Path

sys.path.insert(0, "/usr/local/lib/bedrock")

from lib import view_builder, daemon_setup, state as state_mod, rust_ipc

POLL_INTERVAL_S = 2.0
DAEMON_TOML = Path("/etc/bedrock/daemon.toml")


def daemon_toml_hash() -> bytes:
    if not DAEMON_TOML.exists():
        return b""
    return hashlib.sha256(DAEMON_TOML.read_bytes()).digest()


def main() -> None:
    self_name = state_mod.load().get("node_name", "")
    snapshot = view_builder.empty_snapshot()      # in-memory; live
    last_log_idx = 0
    last_toml_hash = daemon_toml_hash()
    print(f"bedrock-watcher: node={self_name!r}, polling /run/bedrock-rust.sock "
          f"every {POLL_INTERVAL_S}s; daemon-toml at {DAEMON_TOML}",
          flush=True)

    while True:
        time.sleep(POLL_INTERVAL_S)
        try:
            with rust_ipc.Daemon() as d:
                cur_idx = d.status()["latest_index"]
                if cur_idx <= last_log_idx:
                    continue   # log hasn't moved, nothing to fold
                # Fetch ONLY the new entries.
                new_entries = list(d.read(from_index=last_log_idx + 1, to=cur_idx))
        except Exception as e:
            # Daemon down or IPC down — wait for it. Don't reset the
            # snapshot; it stays valid against the same log.
            print(f"watcher: ipc unreachable: {e}", flush=True)
            continue

        if not new_entries:
            last_log_idx = cur_idx
            continue

        # Incremental fold onto the in-memory snapshot.
        view_builder.fold_into(snapshot, new_entries)
        last_log_idx = cur_idx

        # Project the snapshot deterministically into daemon.toml.
        # Re-render even when nothing daemon-relevant changed (cheap),
        # then compare hashes — restart only if content actually
        # differs.
        try:
            daemon_setup.render_from_snapshot(snapshot, self_name)
        except Exception as e:
            print(f"watcher: render_from_snapshot failed: {e}", flush=True)
            continue
        new_hash = daemon_toml_hash()
        if new_hash != last_toml_hash:
            print(f"watcher: log advanced through idx {cur_idx} "
                  f"({len(new_entries)} new); daemon.toml changed; "
                  f"restarting bedrock-rust", flush=True)
            try:
                daemon_setup.restart()
            except Exception as e:
                print(f"watcher: restart failed: {e}", flush=True)
                continue
            last_toml_hash = new_hash
        else:
            # The new entries (e.g. tier_state, vm_*) didn't affect
            # daemon.toml's projection — no daemon restart needed.
            pass


if __name__ == "__main__":
    try:
        main()
    except KeyboardInterrupt:
        sys.exit(0)
