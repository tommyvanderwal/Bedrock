def cmd_vm(args):
    """VM subcommands — delegates to lib/vm.py."""
    from lib import vm as vm_mod
    state = load_state()

    if args.action == "list":
        vm_mod.list_vms(state)
    elif args.action == "create":
        vm_mod.create_vm(state, name=args.name, vm_type=args.type,
