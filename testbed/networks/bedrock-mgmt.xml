<network>
  <name>bedrock-mgmt</name>
  <!-- Bridged onto br0 (which masters enp2s0) — sim nodes appear on the
       real 192.168.2.x LAN, get DHCP from MikroTik, accessible from the
       whole network (including laptop browsing the dashboard). -->
  <forward mode='bridge'/>
  <bridge name='br0'/>
</network>
